# Скопируйте в корень проекта как .env (файл .env в Git не попадает):
#   copy deploy\.env.example .env

# Порт (на хостинге часто задаётся автоматически)
PORT=3000

# production | development
NODE_ENV=development

# URL сайта для CORS (на хостинге — ваш домен, например https://olimp.example.ru)
CORS_ORIGIN=http://localhost:3000

# Путь к SQLite (на VPS с постоянным диском можно указать абсолютный путь)
# DB_PATH=./Server/olymp.db

# Администратор (создаётся/обновляется при каждом запуске сервера)
ADMIN_EMAIL=forestsorokin338@mail.ru
ADMIN_PASSWORD=Shohte12

# В production отключите показ ссылки сброса пароля в ответе API
PASSWORD_RESET_EXPOSE_LINK=0

# Демо-гость для предзащиты (создаётся/обновляется при каждом запуске сервера)
# DEMO_USER_EMAIL=greter12@mail.ru
# DEMO_USER_PASSWORD=great123
# DEMO_USER_PHONE=+7 (915) 000-00-12
